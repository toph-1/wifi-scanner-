    def run(self):
        """Main program loop"""
        while True:
            self.clear_screen()
            self.print_banner()
            self.print_menu()
            
            choice = input("\n[?] Select option (1-6): ").strip()
            
            if choice == '1':
                self.scan_wifi_networks()
                input("\nPress Enter to continue...")
            elif choice == '2':
                self.show_detailed_info()
            elif choice == '3':
                self.export_results()
            elif choice == '4':
                self.security_analysis()
            elif choice == '5':
                self.about()
            elif choice == '6':
                print("\n[✓] Thank you for using toph41k WiFi Scan!")
                print("[✓] Goodbye!\n")
                sys.exit(0)
            else:
                print("[!] Invalid option. Please try again.")
                time.sleep(1)

