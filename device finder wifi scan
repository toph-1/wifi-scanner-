    def display_networks(self):
        """Display networks in a formatted table"""
        print("\n" + "="*80)
        print(f" FOUND {len(self.networks)} NETWORKS - SCAN TIME: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        print("="*80)
        
        print(f"\n{'#':<4} {'SSID':<30} {'Signal':<10} {'Security':<15} {'Channel':<8} {'BSSID'}")
        print("-"*80)
        
        for network in self.networks:
            ssid = network.get('SSID', 'Hidden Network')[:28] + ".." if len(network.get('SSID', '')) > 28 else network.get('SSID', 'Hidden Network')
            signal = network.get('Signal', 'N/A')
            security = network.get('Security', 'N/A')[:13] + ".." if len(network.get('Security', '')) > 13 else network.get('Security', 'N/A')
            channel = network.get('Channel', 'N/A')
            bssid = network.get('BSSID', 'N/A')[:17]
            
            # Color code signal strength
            signal_color = ''
            if 'Signal_Strength' in network:
                if network['Signal_Strength'] > 70:
                    signal_color = '\033[92m'  # Green
                elif network['Signal_Strength'] > 40:
                    signal_color = '\033[93m'  # Yellow
                else:
                    signal_color = '\033[91m'  # Red
                print(f"{network['Number']:<4} {ssid:<30} {signal_color}{signal:<10}\033[0m {security:<15} {channel:<8} {bssid}")
            else:
                print(f"{network['Number']:<4} {ssid:<30} {signal:<10} {security:<15} {channel:<8} {bssid}")
        
        print("\n" + "="*80)
    
    def show_detailed_info(self):
        """Show detailed information for selected network"""
        if not self.networks:
            print("[!] No networks available. Scan first!")
            return
        
        self.display_networks()
        try:
            choice = int(input("\n[?] Enter network number for details (0 to cancel): "))
            if choice == 0:
                return
            
            if 1 <= choice <= len(self.networks):
                network = self.networks[choice-1]
                self.clear_screen()
                print(f"\n{'='*50}")
                print(f"DETAILED INFORMATION FOR: {network.get('SSID', 'Unknown')}")
                print('='*50)
                for key, value in network.items():
                    if key not in ['Number', 'Signal_Strength']:
                        print(f"{key:15}: {value}")
                input("\n\nPress Enter to continue...")
        except:
            print("[!] Invalid selection")
            time.sleep(2)
    
    def export_results(self):
        """Export results to file"""
        if not self.networks:
            print("[!] No networks to export")
            return
        
        filename = f"toph41k_scan_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
        
        try:
            with open(filename, 'w') as f:
                f.write(f"toph41k WiFi Scan - Export File\n")
                f.write(f"Scan Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
                f.write(f"Networks Found: {len(self.networks)}\n")
                f.write("="*60 + "\n\n")
                
                for network in self.networks:
                    f.write(f"Network #{network['Number']}\n")
                    f.write(f"SSID: {network.get('SSID', 'Hidden')}\n")
                    f.write(f"BSSID: {network.get('BSSID', 'N/A')}\n")
                    f.write(f"Signal: {network.get('Signal', 'N/A')}\n")
                    f.write(f"Channel: {network.get('Channel', 'N/A')}\n")
                    f.write(f"Security: {network.get('Security', 'N/A')}\n")
                    f.write("-"*40 + "\n")
            
            print(f"[✓] Results exported to: {filename}")
            time.sleep(2)
        except Exception as e:
            print(f"[!] Error exporting: {e}")
            time.sleep(2)
    
    def security_analysis(self):
        """Analyze network security"""
        if not self.networks:
            print("[!] No networks to analyze")
            return
        
        self.clear_screen()
        print("\n" + "="*50)
        print("NETWORK SECURITY ANALYSIS")
        print("="*50)
        
        open_networks = 0
        secure_networks = 0
        wpa2_networks = 0
        wpa3_networks = 0
        
        for network in self.networks:
            security = network.get('Security', '').upper()
            if 'OPEN' in security or 'NONE' in security:
                open_networks += 1
            elif 'WPA3' in security:
                wpa3_networks += 1
                secure_networks += 1
            elif 'WPA2' in security:
                wpa2_networks += 1
                secure_networks += 1
            elif 'WPA' in security:
                secure_networks += 1
        
        print(f"\nTotal Networks: {len(self.networks)}")
        print(f"Open Networks (Unsecured): {open_networks}")
        print(f"Secured Networks: {secure_networks}")
        print(f"  ├─ WPA2 Networks: {wpa2_networks}")
        print(f"  └─ WPA3 Networks: {wpa3_networks}")
        
        if open_networks > 0:
            print("\n⚠ WARNING: Open networks detected!")
            print("These networks have no encryption and are unsafe for sensitive data!")
        
        input("\nPress Enter to continue...")
    
