    def check_admin_rights(self):
        """Check if running with admin/sudo privileges"""
        try:
            if self.system == "Windows":
                import ctypes
                return ctypes.windll.shell32.IsUserAnAdmin()
            else:  # Linux/Mac
                return os.geteuid() == 0
        except:
            return False
    
    def scan_wifi_networks(self):
        """Main scanning function"""
        self.clear_screen()
        self.print_banner()
        
        print("\n[!] Checking permissions...")
        if not self.check_admin_rights():
            print("[!] Warning: Limited permissions detected!")
            print("[!] For best results, run with administrator/root privileges\n")
            time.sleep(2)
        
        print("[*] Scanning for WiFi networks...")
        print("[*] Please wait...\n")
        
        if self.system == "Windows":
            self.scan_windows()
        elif self.system == "Linux":
            self.scan_linux()
        else:
            print("[!] Unsupported operating system")
            return
        
        if not self.networks:
            print("[!] No networks found or WiFi is disabled!")
        else:
            self.display_networks()
    
    def scan_windows(self):
        """Scan WiFi networks on Windows"""
        try:
            result = subprocess.run(
                ['netsh', 'wlan', 'show', 'networks', 'mode=Bssid'], 
                capture_output=True, text=True, 
                creationflags=subprocess.CREATE_NO_WINDOW if hasattr(subprocess, 'CREATE_NO_WINDOW') else 0
            )
            
            if result.returncode != 0:
                print("[!] Error: Make sure WiFi is enabled")
                return
            
            self.parse_windows_output(result.stdout)
            
        except Exception as e:
            print(f"[!] Error scanning: {e}")
    
    def scan_linux(self):
        """Scan WiFi networks on Linux"""
        try:
            # Bring up WiFi interface
            subprocess.run(['sudo', 'ip', 'link', 'set', 'wlan0', 'up'], 
                         capture_output=True)
            
            # Scan for networks
            result = subprocess.run(
                ['sudo', 'iw', 'dev', 'wlan0', 'scan'], 
                capture_output=True, text=True
            )
            
            if result.returncode != 0:
                print("[!] Error scanning. Try: sudo ip link set wlan0 up")
                return
            
            self.parse_linux_output(result.stdout)
            
        except Exception as e:
            print(f"[!] Error scanning: {e}")
    
    def parse_windows_output(self, output):
        """Parse Windows netsh output"""
        lines = output.split('\n')
        current_network = {}
        
        for i, line in enumerate(lines):
            line = line.strip()
            
            if 'SSID' in line and ':' in line and not 'BSSID' in line:
                if current_network and 'SSID' in current_network:
                    self.networks.append(current_network)
                current_network = {
                    'SSID': line.split(':', 1)[1].strip(),
                    'Number': len(self.networks) + 1
                }
            
            elif 'BSSID' in line and ':' in line:
                current_network['BSSID'] = line.split(':', 1)[1].strip()
            
            elif 'Signal' in line and '%' in line:
                signal = line.split(':', 1)[1].strip()
                current_network['Signal'] = signal
                # Extract just the number for sorting
                try:
                    current_network['Signal_Strength'] = int(signal.replace('%', ''))
                except:
                    current_network['Signal_Strength'] = 0
            
            elif 'Channel' in line:
                current_network['Channel'] = line.split(':', 1)[1].strip()
            
            elif 'Authentication' in line:
                current_network['Security'] = line.split(':', 1)[1].strip()
        
        if current_network and 'SSID' in current_network:
            self.networks.append(current_network)
        
        # Sort by signal strength
        self.networks.sort(key=lambda x: x.get('Signal_Strength', 0), reverse=True)
        
        # Renumber after sorting
        for i, net in enumerate(self.networks, 1):
            net['Number'] = i
    
