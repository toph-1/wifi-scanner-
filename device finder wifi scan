#!/bin/bash

# toph41k WiFi & Device Scanner v2.0
# Scan your network for devices OR scan nearby WiFi networks
# Author: toph41k

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Temporary files
TEMP_DIR="/tmp/toph41k_scan"
DEVICE_RESULTS="$TEMP_DIR/devices.txt"
WIFI_RESULTS="$TEMP_DIR/wifi.txt"
mkdir -p "$TEMP_DIR"

# Function to clear screen
clear_screen() {
    printf "\033c"
}

# Function to print banner
print_banner() {
    echo -e "${BLUE}${BOLD}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║              toph41k WiFi & Device Scanner v2.0               ║"
    echo "║         Scan your network OR scan nearby WiFi networks        ║"
    echo "║                      Author: toph41k                          ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Function to print main menu
print_main_menu() {
    echo -e "${CYAN}${BOLD}MAIN MENU${NC}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  ${WHITE}[1]${NC}  🔍 Scan MY network for connected devices           ║"
    echo "║  ${WHITE}[2]${NC}  📡 Scan OTHER WiFi networks around me              ║"
    echo "║  ${WHITE}[3]${NC}  📊 View scan history                              ║"
    echo "║  ${WHITE}[4]${NC}  ℹ️  Network info                                    ║"
    echo "║  ${WHITE}[5]${NC}  ❌ Exit                                            ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
}

# ==================== DEVICE SCANNER (YOUR NETWORK) ====================

# Function to check and install dependencies for device scanning
check_device_deps() {
    local deps=("arp-scan" "nmap")
    local missing=()
    
    echo -e "${YELLOW}[*] Checking device scanner dependencies...${NC}"
    
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing+=("$dep")
        fi
    done
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}[!] Missing dependencies: ${missing[*]}${NC}"
        echo -e "${YELLOW}[*] Installing...${NC}"
        
        if command -v apt &> /dev/null; then
            sudo apt update
            sudo apt install -y "${missing[@]}"
        elif command -v dnf &> /dev/null; then
            sudo dnf install -y "${missing[@]}"
        elif command -v pacman &> /dev/null; then
            sudo pacman -S "${missing[@]}"
        else
            echo -e "${RED}[!] Please install manually: ${missing[*]}${NC}"
            return 1
        fi
    fi
    
    echo -e "${GREEN}[✓] Device scanner ready${NC}"
    sleep 1
}

# Function to get network info for device scanning
get_network_info() {
    echo -e "${CYAN}[*] Detecting your network configuration...${NC}"
    
    # Get default interface
    INTERFACE=$(ip route | grep default | awk '{print $5}' | head -1)
    
    if [[ -z "$INTERFACE" ]]; then
        INTERFACE=$(ip link | grep -o '^[0-9]: [a-z0-9]*' | grep -v lo | head -1 | cut -d' ' -f2)
    fi
    
    # Get local IP and subnet
    LOCAL_IP=$(ip -4 addr show "$INTERFACE" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -1)
    
    if [[ -z "$LOCAL_IP" ]]; then
        LOCAL_IP=$(hostname -I | awk '{print $1}')
    fi
    
    SUBNET=$(ip route | grep "$INTERFACE" | grep -v default | awk '{print $1}' | head -1)
    
    if [[ -z "$SUBNET" && -n "$LOCAL_IP" ]]; then
        # Calculate subnet from IP
        IP_BASE=$(echo "$LOCAL_IP" | cut -d. -f1-3)
        SUBNET="$IP_BASE.0/24"
    fi
    
    echo -e "${GREEN}[✓] Interface: $INTERFACE${NC}"
    echo -e "${GREEN}[✓] Your IP: $LOCAL_IP${NC}"
    echo -e "${GREEN}[✓] Your network: $SUBNET${NC}"
    echo ""
}

# Function to scan for devices on your network
scan_my_network() {
    clear_screen
    print_banner
    echo -e "${GREEN}${BOLD}🔍 DEVICE SCANNER - Find devices on YOUR network${NC}"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    
    get_network_info
    
    echo -e "${YELLOW}[*] Scanning your network for connected devices...${NC}"
    echo -e "${YELLOW}[*] This takes about 15-30 seconds...${NC}"
    echo ""
    
    # Run arp-scan
    sudo arp-scan --localnet --interface "$INTERFACE" 2>/dev/null | grep -E '([0-9a-f]{2}:){5}[0-9a-f]{2}' > "$DEVICE_RESULTS"
    
    # Check if we got results
    if [[ ! -s "$DEVICE_RESULTS" ]]; then
        echo -e "${RED}[!] No devices found!${NC}"
        echo -e "${YELLOW}[!] Possible issues:${NC}"
        echo "  • WiFi interface might be down"
        echo "  • Try: sudo ip link set $INTERFACE up"
        echo "  • Make sure you're connected to WiFi"
        echo ""
        return 1
    fi
    
    # Display devices
    display_devices
    
    # Save to history
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Device Scan - Found $DEVICE_COUNT devices" >> "$TEMP_DIR/history.txt"
    
    # Device scan submenu
    device_scan_menu
}

# Function to display devices
display_devices() {
    DEVICE_COUNT=0
    declare -A seen_ips
    
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    printf "${WHITE}${BOLD}%-5s %-16s %-20s %-30s${NC}\n" "No." "IP Address" "MAC Address" "Device Info"
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    
    local count=1
    
    while read -r line; do
        # Extract IP and MAC
        ip=$(echo "$line" | awk '{print $1}')
        mac=$(echo "$line" | awk '{print $2}')
        vendor=$(echo "$line" | cut -d' ' -f3- | sed 's/^[ \t]*//')
        
        # Skip duplicates
        if [[ -n "${seen_ips[$ip]}" ]]; then
            continue
        fi
        seen_ips[$ip]=1
        
        # Skip the host machine itself
        if [[ "$ip" == "$LOCAL_IP" ]]; then
            continue
        fi
        
        # Color code based on vendor
        device_color="$NC"
        device_icon="🔹 "
        
        if [[ "$vendor" =~ iPhone|iPad|Apple|iOS|Mac ]]; then
            device_color="$PURPLE"
            device_icon="🍎 "
        elif [[ "$vendor" =~ Samsung|Android|OnePlus|Xiaomi|Huawei|Google ]]; then
            device_color="$GREEN"
            device_icon="📱 "
        elif [[ "$vendor" =~ Intel|Realtek|Broadcom|Atheros|Qualcomm|Microsoft ]]; then
            device_color="$CYAN"
            device_icon="💻 "
        elif [[ "$vendor" =~ Raspberry|Pi|Arduino|Espressif ]]; then
            device_color="$YELLOW"
            device_icon="🤖 "
        elif [[ "$vendor" =~ TP-Link|D-Link|Netgear|Linksys|Asus|Cisco ]]; then
            device_color="$RED"
            device_icon="📡 "
        elif [[ "$vendor" =~ Sony|LG|Samsung|Panasonic|TV|Roku|Amazon ]]; then
            device_color="$BLUE"
            device_icon="📺 "
        elif [[ "$vendor" =~ Canon|HP|Brother|Epson|Printer|Xerox ]]; then
            device_color="$YELLOW"
            device_icon="🖨️ "
        elif [[ "$vendor" =~ Nest|Ring|Ecobee|Smart|Philips|Hue ]]; then
            device_color="$CYAN"
            device_icon="🏠 "
        fi
        
        # Truncate vendor if too long
        if [[ ${#vendor} -gt 28 ]]; then
            vendor="${vendor:0:25}..."
        fi
        
        # Get hostname
        hostname=$(get_hostname "$ip")
        if [[ -n "$hostname" && "$hostname" != "$ip" ]]; then
            vendor="$vendor ($hostname)"
        fi
        
        printf "%-5s ${device_color}%-16s %-20s %s${NC}\n" \
               "$count." "$ip" "$mac" "$device_icon$vendor"
        
        ((count++))
        ((DEVICE_COUNT++))
    done < "$DEVICE_RESULTS"
    
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}Total devices found: $DEVICE_COUNT${NC}"
    echo ""
}

# Function to get hostname
get_hostname() {
    local ip=$1
    local hostname=""
    
    # Try nmblookup
    if command -v nmblookup &> /dev/null; then
        hostname=$(nmblookup -A "$ip" 2>/dev/null | grep -i "<00>" | grep -v "GROUP" | head -1 | awk '{print $1}')
    fi
    
    # Try reverse DNS
    if [[ -z "$hostname" && -f /usr/bin/dig ]]; then
        hostname=$(dig +short -x "$ip" 2>/dev/null | sed 's/\.$//')
    fi
    
    echo "$hostname"
}

# Device scan submenu
device_scan_menu() {
    while true; do
        echo -e "${CYAN}${BOLD}DEVICE SCAN OPTIONS:${NC}"
        echo "╔════════════════════════════════════════════════════════╗"
        echo "║  ${WHITE}[1]${NC}  Deep scan a specific device                     ║"
        echo "║  ${WHITE}[2]${NC}  Export results                                 ║"
        echo "║  ${WHITE}[3]${NC}  Scan again                                     ║"
        echo "║  ${WHITE}[4]${NC}  Back to main menu                              ║"
        echo "╚════════════════════════════════════════════════════════╝"
        echo ""
        echo -ne "${GREEN}Select option: ${NC}"
        read device_choice
        
        case $device_choice in
            1)
                deep_scan_device
                ;;
            2)
                export_device_results
                ;;
            3)
                scan_my_network
                break
                ;;
            4)
                return
                ;;
            *)
                echo -e "${RED}[!] Invalid option${NC}"
                sleep 1
                ;;
        esac
    done
}

# Function to deep scan a device
deep_scan_device() {
    echo -ne "${CYAN}Enter device number to deep scan: ${NC}"
    read choice
    
    if [[ -z "$choice" ]]; then
        return
    fi
    
    # Get IP of selected device
    target_ip=$(sed -n "${choice}p" "$DEVICE_RESULTS" | awk '{print $1}')
    
    if [[ -z "$target_ip" ]]; then
        echo -e "${RED}[!] Invalid selection${NC}"
        sleep 2
        return
    fi
    
    echo -e "${YELLOW}[*] Deep scanning $target_ip...${NC}"
    echo ""
    
    # Scan common ports
    echo -e "${BLUE}Open Ports:${NC}"
    sudo nmap -sS -T4 -p 21,22,23,25,53,80,110,111,135,139,143,443,445,993,995,1723,3306,3389,5900,8080 "$target_ip" 2>/dev/null | grep -E '^[0-9]+/tcp' | sed 's/^/  /'
    
    # Detect OS
    echo -e "\n${BLUE}OS Detection:${NC}"
    sudo nmap -O "$target_ip" 2>/dev/null | grep -E "OS details|Running|OS guess" | sed 's/^/  /'
    
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read
}

# Function to export device results
export_device_results() {
    local filename="toph41k_devices_$(date '+%Y%m%d_%H%M%S').txt"
    
    {
        echo "toph41k Device Scanner - Export File"
        echo "Scan Date: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "Your Network: $SUBNET"
        echo "Your IP: $LOCAL_IP"
        echo "=================================================="
        echo ""
        echo "Devices Found:"
        echo "--------------"
        
        local count=1
        while read -r line; do
            ip=$(echo "$line" | awk '{print $1}')
            mac=$(echo "$line" | awk '{print $2}')
            vendor=$(echo "$line" | cut -d' ' -f3-)
            
            if [[ "$ip" != "$LOCAL_IP" ]]; then
                echo "$count. IP: $ip"
                echo "   MAC: $mac"
                echo "   Device: $vendor"
                hostname=$(get_hostname "$ip")
                if [[ -n "$hostname" && "$hostname" != "$ip" ]]; then
                    echo "   Hostname: $hostname"
                fi
                echo ""
                ((count++))
            fi
        done < "$DEVICE_RESULTS"
        
    } > "$filename"
    
    echo -e "${GREEN}[✓] Results exported to: $filename${NC}"
    sleep 2
}

# ==================== WIFI SCANNER (OTHER NETWORKS) ====================

# Function to check WiFi scanner dependencies
check_wifi_deps() {
    if ! command -v nmcli &> /dev/null; then
        echo -e "${YELLOW}[*] Installing network-manager for WiFi scanning...${NC}"
        if command -v apt &> /dev/null; then
            sudo apt install -y network-manager
        elif command -v dnf &> /dev/null; then
            sudo dnf install -y NetworkManager
        elif command -v pacman &> /dev/null; then
            sudo pacman -S networkmanager
        fi
    fi
    echo -e "${GREEN}[✓] WiFi scanner ready${NC}"
}

# Function to scan other WiFi networks
scan_other_wifis() {
    clear_screen
    print_banner
    echo -e "${GREEN}${BOLD}📡 WIFI SCANNER - Find OTHER WiFi networks around you${NC}"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    
    # Enable WiFi if disabled
    if command -v nmcli &> /dev/null; then
        wifi_status=$(nmcli radio wifi)
        if [[ "$wifi_status" == "disabled" ]]; then
            echo -e "${YELLOW}[*] Enabling WiFi...${NC}"
            nmcli radio wifi on
            sleep 2
        fi
    fi
    
    echo -e "${YELLOW}[*] Scanning for nearby WiFi networks...${NC}"
    echo -e "${YELLOW}[*] Please wait...${NC}"
    echo ""
    
    # Try different scanning methods
    if command -v nmcli &> /dev/null; then
        scan_wifi_nmcli
    elif command -v iwlist &> /dev/null; then
        scan_wifi_iwlist
    else
        echo -e "${RED}[!] No WiFi scanning tool found!${NC}"
        return 1
    fi
    
    # Save to history
    echo "$(date '+%Y-%m-%d %H:%M:%S') - WiFi Scan - Found $WIFI_COUNT networks" >> "$TEMP_DIR/history.txt"
    
    # WiFi scan submenu
    wifi_scan_menu
}

# Scan with nmcli
scan_wifi_nmcli() {
    # Get WiFi list
    local temp_file="$WIFI_RESULTS"
    nmcli -t -f SSID,SIGNAL,SECURITY,CHAN,BSSID device wifi list > "$temp_file" 2>/dev/null
    
    if [[ ! -s "$temp_file" ]]; then
        echo -e "${RED}[!] No networks found or WiFi is disabled${NC}"
        return 1
    fi
    
    WIFI_COUNT=0
    
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    printf "${WHITE}${BOLD}%-5s %-30s %-10s %-15s %-8s %s${NC}\n" "No." "Network Name (SSID)" "Signal" "Security" "Channel" "BSSID"
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    
    local count=1
    while IFS=: read -r ssid signal security channel bssid; do
        # Skip empty or hidden networks
        if [[ -z "$ssid" || "$ssid" == "--" ]]; then
            ssid="Hidden Network"
        fi
        
        # Clean up SSID
        ssid=$(echo "$ssid" | tr -d '\\')
        
        # Color code signal
        if [[ $signal -gt 70 ]]; then
            signal_color="${GREEN}"
        elif [[ $signal -gt 40 ]]; then
            signal_color="${YELLOW}"
        else
            signal_color="${RED}"
        fi
        
        # Truncate long SSID
        if [[ ${#ssid} -gt 27 ]]; then
            ssid="${ssid:0:24}..."
        fi
        
        # Format security (truncate if needed)
        if [[ ${#security} -gt 13 ]]; then
            security="${security:0:10}..."
        fi
        
        printf "%-5s %-30s ${signal_color}%-10s${NC} %-15s %-8s %s\n" \
               "$count." "$ssid" "${signal}%" "$security" "${channel:-N/A}" "${bssid:0:17}"
        
        ((count++))
        ((WIFI_COUNT++))
    done < "$temp_file"
    
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}Total networks found: $WIFI_COUNT${NC}"
    echo ""
}

# Scan with iwlist (backup)
scan_wifi_iwlist() {
    # Find wireless interface
    local interface=$(iwconfig 2>/dev/null | grep -o '^[a-zA-Z0-9]*' | head -1)
    
    if [[ -z "$interface" ]]; then
        interface="wlan0"
    fi
    
    # Bring interface up
    ip link set "$interface" up 2>/dev/null
    
    # Scan
    local temp_file="/tmp/iwlist_scan.txt"
    iwlist "$interface" scan 2>/dev/null > "$temp_file"
    
    if [[ ! -s "$temp_file" ]]; then
        echo -e "${RED}[!] No networks found${NC}"
        return 1
    fi
    
    WIFI_COUNT=0
    
    echo -e "${BLUE}${BOLD}════════════════════════════════════════════════════════════════${NC}"
    printf "${WHITE}${BOLD}%-5s %-30s %-10s${NC}\n" "No." "Network Name (SSID)" "Signal"
    echo -e "${BLUE}${BOLD}════════════════════════════════════════════════════════════════${NC}"
    
    local count=1
    local current_ssid=""
    local current_quality=""
    
    while IFS= read -r line; do
        if [[ "$line" =~ ESSID:\"([^\"]*)\" ]]; then
            current_ssid="${BASH_REMATCH[1]}"
            if [[ -z "$current_ssid" ]]; then
                current_ssid="Hidden Network"
            fi
        fi
        
        if [[ "$line" =~ Quality=([0-9]+)/([0-9]+) ]]; then
            current_quality=$(((${BASH_REMATCH[1]} * 100) / ${BASH_REMATCH[2]}))
            
            if [[ -n "$current_ssid" ]]; then
                if [[ $current_quality -gt 70 ]]; then
                    signal_color="${GREEN}"
                elif [[ $current_quality -gt 40 ]]; then
                    signal_color="${YELLOW}"
                else
                    signal_color="${RED}"
                fi
                
                if [[ ${#current_ssid} -gt 27 ]]; then
                    current_ssid="${current_ssid:0:24}..."
                fi
                
                printf "%-5s %-30s ${signal_color}%-10s${NC}\n" \
                       "$count." "$current_ssid" "${current_quality}%"
                
                ((count++))
                ((WIFI_COUNT++))
                current_ssid=""
            fi
        fi
    done < "$temp_file"
    
    rm -f "$temp_file"
    
    echo -e "${BLUE}${BOLD}════════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}Total networks found: $WIFI_COUNT${NC}"
    echo ""
}

# WiFi scan submenu
wifi_scan_menu() {
    while true; do
        echo -e "${CYAN}${BOLD}WIFI SCAN OPTIONS:${NC}"
        echo "╔════════════════════════════════════════════════════════╗"
        echo "║  ${WHITE}[1]${NC}  Show WiFi details                               ║"
        echo "║  ${WHITE}[2]${NC}  Export WiFi list                                ║"
        echo "║  ${WHITE}[3]${NC}  Scan again                                      ║"
        echo "║  ${WHITE}[4]${NC}  Back to main menu                               ║"
        echo "╚════════════════════════════════════════════════════════╝"
        echo ""
        echo -ne "${GREEN}Select option: ${NC}"
        read wifi_choice
        
        case $wifi_choice in
            1)
                show_wifi_details
                ;;
            2)
                export_wifi_results
                ;;
            3)
                scan_other_wifis
                break
                ;;
            4)
                return
                ;;
            *)
                echo -e "${RED}[!] Invalid option${NC}"
                sleep 1
                ;;
