#!/bin/bash

# toph41k Network Device Scanner v1.0
# Scans your local network for connected devices
# Author: toph41k

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Temporary files
TEMP_DIR="/tmp/toph41k_scan"
RESULTS_FILE="$TEMP_DIR/devices.txt"
mkdir -p "$TEMP_DIR"

# Function to clear screen
clear_screen() {
    printf "\033c"
}

# Function to print banner
print_banner() {
    echo -e "${BLUE}${BOLD}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║              toph41k Network Device Scanner v1.0              ║"
    echo "║              Find all devices connected to your WiFi          ║"
    echo "║                      Author: toph41k                          ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Function to check and install dependencies
check_deps() {
    local deps=("arp-scan" "nmap")
    local missing=()
    
    echo -e "${YELLOW}[*] Checking dependencies...${NC}"
    
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing+=("$dep")
        fi
    done
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}[!] Missing dependencies: ${missing[*]}${NC}"
        echo -e "${YELLOW}[*] Installing...${NC}"
        
        if command -v apt &> /dev/null; then
            sudo apt update
            sudo apt install -y "${missing[@]}"
        elif command -v dnf &> /dev/null; then
            sudo dnf install -y "${missing[@]}"
        elif command -v pacman &> /dev/null; then
            sudo pacman -S "${missing[@]}"
        else
            echo -e "${RED}[!] Please install manually: ${missing[*]}${NC}"
            exit 1
        fi
    fi
    
    echo -e "${GREEN}[✓] All dependencies satisfied${NC}"
    sleep 1
}

# Function to get network info
get_network_info() {
    echo -e "${CYAN}[*] Detecting network configuration...${NC}"
    
    # Get default interface
    INTERFACE=$(ip route | grep default | awk '{print $5}' | head -1)
    
    if [[ -z "$INTERFACE" ]]; then
        INTERFACE="wlan0"
    fi
    
    # Get local IP and subnet
    LOCAL_IP=$(ip -4 addr show "$INTERFACE" | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -1)
    SUBNET=$(ip route | grep "$INTERFACE" | grep -v default | awk '{print $1}' | head -1)
    
    if [[ -z "$SUBNET" ]]; then
        # Calculate subnet from IP
        IP_BASE=$(echo "$LOCAL_IP" | cut -d. -f1-3)
        SUBNET="$IP_BASE.0/24"
    fi
    
    echo -e "${GREEN}[✓] Interface: $INTERFACE${NC}"
    echo -e "${GREEN}[✓] Your IP: $LOCAL_IP${NC}"
    echo -e "${GREEN}[✓] Scanning subnet: $SUBNET${NC}"
    echo ""
}

# Function to scan with arp-scan (fast and reliable)
scan_with_arp() {
    echo -e "${YELLOW}[*] Scanning network with ARP (this takes about 10-30 seconds)...${NC}"
    echo ""
    
    # Run arp-scan
    sudo arp-scan --localnet --interface "$INTERFACE" 2>/dev/null | grep -E '([0-9a-f]{2}:){5}[0-9a-f]{2}' > "$RESULTS_FILE"
    
    # Check if we got results
    if [[ ! -s "$RESULTS_FILE" ]]; then
        echo -e "${RED}[!] No devices found with ARP scan${NC}"
        return 1
    fi
    
    # Count devices
    DEVICE_COUNT=$(wc -l < "$RESULTS_FILE")
    
    echo -e "${GREEN}[✓] Found $DEVICE_COUNT devices${NC}"
    echo ""
    
    # Display results in a nice table
    display_devices
}

# Function to display devices in a formatted table
display_devices() {
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    printf "${WHITE}${BOLD}%-5s %-16s %-20s %-30s${NC}\n" "No." "IP Address" "MAC Address" "Device Info"
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    
    local count=1
    declare -A seen_ips
    
    while read -r line; do
        # Extract IP and MAC
        ip=$(echo "$line" | awk '{print $1}')
        mac=$(echo "$line" | awk '{print $2}')
        vendor=$(echo "$line" | cut -d' ' -f3- | sed 's/^[ \t]*//')
        
        # Skip duplicates
        if [[ -n "${seen_ips[$ip]}" ]]; then
            continue
        fi
        seen_ips[$ip]=1
        
        # Skip the host machine itself
        if [[ "$ip" == "$LOCAL_IP" ]]; then
            continue
        fi
        
        # Color code based on vendor/device type
        device_color="$NC"
        device_icon=""
        
        if [[ "$vendor" =~ iPhone|iPad|Apple|iOS ]]; then
            device_color="$PURPLE"
            device_icon="🍎 "
        elif [[ "$vendor" =~ Samsung|Android|OnePlus|Xiaomi|Huawei ]]; then
            device_color="$GREEN"
            device_icon="📱 "
        elif [[ "$vendor" =~ Intel|Realtek|Broadcom|Atheros|Qualcomm ]]; then
            device_color="$CYAN"
            device_icon="💻 "
        elif [[ "$vendor" =~ Raspberry|Pi|Arduino ]]; then
            device_color="$YELLOW"
            device_icon="🤖 "
        elif [[ "$vendor" =~ TP-Link|D-Link|Netgear|Linksys|Asus ]]; then
            device_color="$RED"
            device_icon="📡 "
        elif [[ "$vendor" =~ Sony|LG|Samsung|Panasonic|TV ]]; then
            device_color="$BLUE"
            device_icon="📺 "
        elif [[ "$vendor" =~ Canon|HP|Brother|Epson|Printer ]]; then
            device_color="$YELLOW"
            device_icon="🖨️ "
        else
            device_color="$WHITE"
            device_icon="🔹 "
        fi
        
        # Truncate vendor if too long
        if [[ ${#vendor} -gt 28 ]]; then
            vendor="${vendor:0:25}..."
        fi
        
        # Get hostname if available
        hostname=$(get_hostname "$ip")
        if [[ -n "$hostname" && "$hostname" != "$ip" ]]; then
            vendor="$vendor ($hostname)"
        fi
        
        printf "%-5s ${device_color}%-16s %-20s %s${NC}\n" \
               "$count." "$ip" "$mac" "$device_icon$vendor"
        
        ((count++))
    done < "$RESULTS_FILE"
    
    echo -e "${BLUE}${BOLD}══════════════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}Total active devices: $((count-1))${NC}"
    echo ""
}

# Function to get hostname for IP
get_hostname() {
    local ip=$1
    local hostname=""
    
    # Try to get hostname via nmblookup (NetBIOS)
    if command -v nmblookup &> /dev/null; then
        hostname=$(nmblookup -A "$ip" 2>/dev/null | grep -i "<00>" | grep -v "GROUP" | head -1 | awk '{print $1}')
    fi
    
    # Try reverse DNS if nmblookup failed
    if [[ -z "$hostname" ]]; then
        hostname=$(dig +short -x "$ip" 2>/dev/null | sed 's/\.$//')
    fi
    
    echo "$hostname"
}

# Function to do deep scan with nmap
deep_scan() {
    echo -e "${YELLOW}[*] Performing detailed device analysis (this takes about 1-2 minutes)...${NC}"
    echo ""
    
    # Ask for device number
    display_devices
    echo -ne "${CYAN}Enter device number for deep scan (0 to skip): ${NC}"
    read choice
    
    if [[ "$choice" == "0" || -z "$choice" ]]; then
        return
    fi
    
    # Get IP of selected device
    target_ip=$(sed -n "${choice}p" "$RESULTS_FILE" | awk '{print $1}')
    
    if [[ -z "$target_ip" ]]; then
        echo -e "${RED}[!] Invalid selection${NC}"
        sleep 2
        return
    fi
    
    echo -e "${YELLOW}[*] Deep scanning $target_ip...${NC}"
    echo ""
    
    # Scan common ports
    echo -e "${BLUE}Open Ports:${NC}"
    sudo nmap -sS -T4 -p 21,22,23,25,53,80,110,111,135,139,143,443,445,993,995,1723,3306,3389,5900,8080 "$target_ip" | grep -E '^[0-9]+/tcp' | sed 's/^/  /'
    
    # Detect OS
    echo -e "\n${BLUE}OS Detection:${NC}"
    sudo nmap -O "$target_ip" 2>/dev/null | grep -E "OS details|Running|OS guess" | sed 's/^/  /'
    
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read
}

# Function to export results
export_results() {
    if [[ ! -f "$RESULTS_FILE" ]]; then
        echo -e "${RED}[!] No scan results to export${NC}"
        sleep 2
        return
    fi
    
    local filename="toph41k_devices_$(date '+%Y%m%d_%H%M%S').txt"
    
    {
        echo "toph41k Network Device Scanner - Export File"
        echo "Scan Date: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "Network: $SUBNET"
        echo "Your IP: $LOCAL_IP"
        echo "=================================================="
        echo ""
        echo "Devices Found:"
        echo "--------------"
        
        local count=1
        while read -r line; do
            ip=$(echo "$line" | awk '{print $1}')
            mac=$(echo "$line" | awk '{print $2}')
            vendor=$(echo "$line" | cut -d' ' -f3-)
            
            if [[ "$ip" != "$LOCAL_IP" ]]; then
                echo "$count. IP: $ip"
                echo "   MAC: $mac"
                echo "   Device: $vendor"
                hostname=$(get_hostname "$ip")
                if [[ -n "$hostname" && "$hostname" != "$ip" ]]; then
                    echo "   Hostname: $hostname"
                fi
                echo ""
                ((count++))
            fi
        done < "$RESULTS_FILE"
        
    } > "$filename"
    
    echo -e "${GREEN}[✓] Results exported to: $filename${NC}"
    sleep 2
}

# Main menu function
show_menu() {
    while true; do
        clear_screen
        print_banner
        
        echo -e "${CYAN}${BOLD}MAIN MENU${NC}"
        echo "╔════════════════════════════════════════════════════╗"
        echo "║  ${WHITE}[1]${NC}  Scan for devices (ARP scan)                   ║"
        echo "║  ${WHITE}[2]${NC}  Deep scan specific device                     ║"
        echo "║  ${WHITE}[3]${NC}  Export results to file                        ║"
        echo "║  ${WHITE}[4]${NC}  Show network info                             ║"
        echo "║  ${WHITE}[5]${NC}  Exit                                          ║"
        echo "╚════════════════════════════════════════════════════╝"
        echo ""
        echo -ne "${GREEN}Select option (1-5): ${NC}"
        read choice
        
        case $choice in
            1)
                clear_screen
                print_banner
                get_network_info
                scan_with_arp
                echo -e "\n${YELLOW}Press Enter to continue...${NC}"
                read
                ;;
            2)
                if [[ ! -f "$RESULTS_FILE" ]]; then
                    echo -e "${RED}[!] Please scan first (option 1)${NC}"
                    sleep 2
                else
                    deep_scan
                fi
                ;;
            3)
                export_results
                ;;
            4)
                clear_screen
                print_banner
                get_network_info
                echo -e "\n${YELLOW}Press Enter to continue...${NC}"
                read
                ;;
            5)
                echo -e "\n${GREEN}[✓] Goodbye!${NC}"
                rm -rf "$TEMP_DIR"
                exit 0
                ;;
            *)
                echo -e "${RED}[!] Invalid option${NC}"
                sleep 1
                ;;
        esac
    done
}

# Function to show quick scan (one-liner version)
quick_scan() {
    echo -e "${GREEN}Quick device scan:${NC}"
    echo "=================="
    
    # Get subnet
    local subnet=$(ip route | grep -v default | grep wlan0 | awk '{print $1}' | head -1)
    if [[ -z "$subnet" ]]; then
        local ip=$(hostname -I | awk '{print $1}')
        local base=$(echo "$ip" | cut -d. -f1-3)
        subnet="$base.0/24"
    fi
    
    # Quick ARP scan
    sudo arp-scan "$subnet" 2>/dev/null | grep -E '([0-9a-f]{2}:){5}[0-9a-f]{2}' | while read -r line; do
        ip=$(echo "$line" | awk '{print $1}')
        mac=$(echo "$line" | awk '{print $2}')
        vendor=$(echo "$line" | cut -d' ' -f3-)
        printf "%-15s %-17s %s\n" "$ip" "$mac" "$vendor"
    done
}

# Main execution
main() {
    # Check if running as root
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}[!] This script must be run as root (sudo)${NC}"
        echo -e "${YELLOW}Usage: sudo $0${NC}"
        exit 1
    fi
    
    # Check for quick mode
    if [[ "$1" == "--quick" ]]; then
        get_network_info
        quick_scan
        exit 0
    fi
    
    # Normal mode
    check_deps
    show_menu
}

# Run main function with arguments
main "$@"
