GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Global variables
VERSION="1.0"
SCAN_RESULTS="/tmp/toph41k_scan_results.txt"
NETWORKS=()

