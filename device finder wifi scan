#!/bin/bash

# toph41k WiFi Scan v1.0 - Simple Version
# Author: toph41k

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

clear
echo "========================================"
echo "   toph41k WiFi Network Scanner"
echo "========================================"
echo ""

# Check if running as root
if [[ $EUID -ne 0 ]]; then
    echo -e "${YELLOW}Note: Run with 'sudo' for better results${NC}"
    echo ""
fi

# Function to scan WiFi
scan_wifi() {
    echo "Scanning for WiFi networks..."
    echo "Please wait..."
    echo ""
    
    # Try different scanning methods
    if command -v nmcli &> /dev/null; then
        # Method 1: nmcli (fastest and cleanest)
        scan_with_nmcli
    elif command -v iwlist &> /dev/null; then
        # Method 2: iwlist
        scan_with_iwlist
    else
        echo -e "${RED}Error: No WiFi scanning tool found${NC}"
        echo "Install network-manager or wireless-tools"
        exit 1
    fi
}

# Scan with nmcli
scan_with_nmcli() {
    # Get WiFi list
    TEMP_FILE=$(mktemp)
    nmcli -t -f SSID,SIGNAL,SECURITY device wifi list > "$TEMP_FILE" 2>/dev/null
    
    if [[ ! -s "$TEMP_FILE" ]]; then
        echo -e "${RED}No networks found or WiFi is disabled${NC}"
        rm "$TEMP_FILE"
        return
    fi
    
    echo "========================================"
    echo " Available Networks"
    echo "========================================"
    echo ""
    
    # Display header
    printf "%-4s %-30s %-10s %s\n" "No." "Network Name (SSID)" "Signal" "Security"
    echo "------------------------------------------------"
    
    # Process and display each network
    count=1
    while IFS=: read -r ssid signal security; do
        # Skip empty or hidden networks
        if [[ -z "$ssid" ]] || [[ "$ssid" == "--" ]]; then
            continue
        fi
        
        # Clean up SSID
        ssid=$(echo "$ssid" | tr -d '\\')
        
        # Color code signal strength
        if [[ $signal -gt 70 ]]; then
            signal_color="${GREEN}"
        elif [[ $signal -gt 40 ]]; then
            signal_color="${YELLOW}"
        else
            signal_color="${RED}"
        fi
        
        # Truncate long SSID
        if [[ ${#ssid} -gt 27 ]]; then
            ssid="${ssid:0:24}..."
        fi
        
        # Print network info
        printf "%-4s %-30s ${signal_color}%-10s${NC} %s\n" \
               "$count." "$ssid" "${signal}%" "$security"
        
        ((count++))
    done < "$TEMP_FILE"
    
    rm "$TEMP_FILE"
    
    echo ""
    echo "========================================"
}

# Scan with iwlist (backup method)
scan_with_iwlist() {
    # Find wireless interface
    INTERFACE=$(iwconfig 2>/dev/null | grep -o '^[a-zA-Z0-9]*' | head -1)
    
    if [[ -z "$INTERFACE" ]]; then
        INTERFACE="wlan0"
    fi
    
    # Bring interface up
    ip link set $INTERFACE up 2>/dev/null
    
    # Scan
    TEMP_FILE=$(mktemp)
    iwlist $INTERFACE scan 2>/dev/null > "$TEMP_FILE"
    
    if [[ ! -s "$TEMP_FILE" ]]; then
        echo -e "${RED}No networks found${NC}"
        rm "$TEMP_FILE"
        return
    fi
    
    echo "========================================"
    echo " Available Networks"
    echo "========================================"
    echo ""
    
    # Display header
    printf "%-4s %-30s %-10s\n" "No." "Network Name (SSID)" "Signal"
    echo "------------------------------------------------"
    
    # Parse iwlist output
    count=1
    current_ssid=""
    current_quality=""
    
    while IFS= read -r line; do
        # Extract SSID
        if [[ "$line" =~ ESSID:\"([^\"]*)\" ]]; then
            current_ssid="${BASH_REMATCH[1]}"
            if [[ -z "$current_ssid" ]]; then
                current_ssid="Hidden Network"
            fi
        fi
        
        # Extract quality
        if [[ "$line" =~ Quality=([0-9]+)/([0-9]+) ]]; then
            quality=$(((${BASH_REMATCH[1]} * 100) / ${BASH_REMATCH[2]}))
            current_quality="$quality"
            
            # Print network when we have both SSID and quality
            if [[ -n "$current_ssid" ]]; then
                # Color code signal
                if [[ $current_quality -gt 70 ]]; then
                    signal_color="${GREEN}"
                elif [[ $current_quality -gt 40 ]]; then
                    signal_color="${YELLOW}"
                else
                    signal_color="${RED}"
                fi
                
                # Truncate long SSID
                if [[ ${#current_ssid} -gt 27 ]]; then
                    current_ssid="${current_ssid:0:24}..."
                fi
                
                printf "%-4s %-30s ${signal_color}%-10s${NC}\n" \
                       "$count." "$current_ssid" "${current_quality}%"
                
                ((count++))
                current_ssid=""
                current_quality=""
            fi
        fi
    done < "$TEMP_FILE"
    
    rm "$TEMP_FILE"
    
    echo ""
    echo "========================================"
}

# Function to show details for a specific network
show_details() {
    if [[ $# -eq 0 ]]; then
        echo -e "${YELLOW}Enter the network number:${NC} "
        read num
    else
        num=$1
    fi
    
    # Get network details using nmcli
    if command -v nmcli &> /dev/null; then
        TEMP_FILE=$(mktemp)
        nmcli -f ALL device wifi list > "$TEMP_FILE" 2>/dev/null
        
        # Skip header line and get the selected network
        line_num=$((num + 1))
        network_info=$(sed -n "${line_num}p" "$TEMP_FILE")
        
        if [[ -n "$network_info" ]]; then
            echo ""
            echo "========================================"
            echo " Network Details"
            echo "========================================"
            echo "$network_info" | sed 's/^/ /'
            echo "========================================"
        else
            echo -e "${RED}Network not found${NC}"
        fi
        
        rm "$TEMP_FILE"
    fi
}

# Main menu
while true; do
    scan_wifi
    
    echo ""
    echo "Options:"
    echo "  [1] Scan again"
    echo "  [2] Show network details (enter number)"
    echo "  [3] Exit"
    echo ""
    echo -n "Choose (1-3): "
    read option
    
    case $option in
        1)
            clear
            continue
            ;;
        2)
            echo ""
            echo -n "Enter network number: "
            read net_num
            if [[ "$net_num" =~ ^[0-9]+$ ]]; then
                show_details $net_num
                echo ""
                echo -n "Press Enter to continue..."
                read
            else
                echo -e "${RED}Invalid number${NC}"
                sleep 1
            fi
            clear
            ;;
        3)
            echo ""
            echo "Goodbye!"
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid option${NC}"
            sleep 1
            clear
            ;;
    esac
done
