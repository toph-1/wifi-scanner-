}

# Function to show WiFi details
show_wifi_details() {
    echo -ne "${CYAN}Enter network number for details: ${NC}"
    read choice
    
    if [[ -z "$choice" ]]; then
        return
    fi
    
    if command -v nmcli &> /dev/null; then
        local temp_file=$(mktemp)
        nmcli -f ALL device wifi list > "$temp_file" 2>/dev/null
        
        local line_num=$((choice + 1))
        local network_info=$(sed -n "${line_num}p" "$temp_file")
        
        if [[ -n "$network_info" ]]; then
            echo ""
            echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
            echo -e "${WHITE}Network Details:${NC}"
            echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
            echo "$network_info" | sed 's/^/  /'
            echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
        else
            echo -e "${RED}[!] Network not found${NC}"
        fi
        
        rm "$temp_file"
    fi
    
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read
}

# Function to export WiFi results
export_wifi_results() {
    local filename="toph41k_wifis_$(date '+%Y%m%d_%H%M%S').txt"
    
    {
        echo "toph41k WiFi Scanner - Export File"
        echo "Scan Date: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "=================================================="
        echo ""
        echo "Nearby WiFi Networks:"
        echo "--------------------"
        
        if command -v nmcli &> /dev/null; then
            nmcli -f SSID,SIGNAL,SECURITY,CHAN,BSSID device wifi list >> "$filename"
        fi
        
    } > "$filename"
    
    echo -e "${GREEN}[✓] Results exported to: $filename${NC}"
    sleep 2
}

# ==================== HISTORY VIEWER ====================

view_history() {
    clear_screen
    print_banner
    echo -e "${GREEN}${BOLD}📊 SCAN HISTORY${NC}"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    
    if [[ -f "$TEMP_DIR/history.txt" ]]; then
        cat "$TEMP_DIR/history.txt"
    else
        echo -e "${YELLOW}No scan history yet.${NC}"
    fi
    
    echo ""
    echo -e "${YELLOW}Press Enter to continue...${NC}"
    read
}

# ==================== NETWORK INFO ====================

show_network_info() {
    clear_screen
    print_banner
    echo -e "${GREEN}${BOLD}ℹ️  NETWORK INFORMATION${NC}"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    
    echo -e "${CYAN}Network Interfaces:${NC}"
    ip -4 addr show | grep -E '^[0-9]|inet ' | grep -v '127.0.0.1' | sed 's/^/  /'
    
    echo ""
    echo -e "${CYAN}WiFi Status:${NC}"
    if command -v nmcli &> /dev/null; then
        echo "  WiFi Radio: $(nmcli radio wifi)"
        echo "  Connected to: $(nmcli -t -f NAME connection show --active | head -1)"
    fi
    
    echo ""
    echo -e "${CYAN}Default Gateway:${NC}"
    ip route | grep default | sed 's/^/  /'
    
    echo ""
    echo -e "${CYAN}DNS Servers:${NC}"
    cat /etc/resolv.conf 2>/dev/null | grep nameserver | sed 's/^/  /'
    
    echo ""
    echo -e "${YELLOW}Press Enter to continue...${NC}"
    read
}

# ==================== MAIN ====================

# Main function
main() {
    # Check if running as root
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}[!] This script must be run as root (sudo)${NC}"
        echo -e "${YELLOW}Usage: sudo $0${NC}"
        exit 1
    fi
    
    # Main menu loop
    while true; do
        clear_screen
        print_banner
        print_main_menu
        
        echo -ne "${GREEN}Select option (1-5): ${NC}"
        read choice
        
        case $choice in
            1)
                check_device_deps
                scan_my_network
                ;;
            2)
                check_wifi_deps
                scan_other_wifis
                ;;
            3)
                view_history
                ;;
            4)
                show_network_info
                ;;
            5)
                echo -e "\n${GREEN}[✓] Goodbye!${NC}"
                rm -rf "$TEMP_DIR" 2>/dev/null
                exit 0
                ;;
            *)
                echo -e "${RED}[!] Invalid option${NC}"
                sleep 1
                ;;
        esac
    done
}

# Run main
main "$@"
